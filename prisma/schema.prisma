generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
}

// ── NextAuth Prisma Adapter models ──────────────────────────────────────────

model User {
  id                      String    @id @default(cuid())
  name                    String?
  email                   String?   @unique
  emailVerified           DateTime?
  image                   String?
  role                    String    @default("user") // "admin" | "user"
  stripeCustomerId        String?
  billingAddress          Json?     // { name, line1, line2?, city, postalCode, country }
  defaultPaymentMethodId  String?
  accounts                Account[]
  sessions                Session[]
  docRuns                 DocRun[]
  connectedServices       ConnectedService[]
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Billing ──────────────────────────────────────────────────────────────────

model DocRun {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId             String   @unique  // matches ephemeral stream sessionId
  modelId               String
  spendingLimitEur      Float?
  totalInputTokens      Int      @default(0)
  totalOutputTokens     Int      @default(0)
  estimatedCostEur      Float    @default(0)
  status                String   @default("active") // "active" | "checked_out" | "paid" | "abandoned"
  stripePaymentIntentId String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
  @@index([sessionId])
  @@index([status])
  @@map("doc_runs")
}

// ── Connected Services ────────────────────────────────────────────────────────

model ConnectedService {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String   // "google_drive" | "github" | "notion" | "confluence" | ...
  accessToken  String   @db.Text  // AES-256-GCM encrypted
  refreshToken String?  @db.Text  // AES-256-GCM encrypted
  expiresAt    DateTime?
  metadata     Json?    // provider-specific: { defaultFolderId } | { repoOwner, repoName, branch }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
  @@map("connected_services")
}

// ── Existing models ───────────────────────────────────────────────────────────

model GeneratedDocument {
  id            String   @id @default(cuid())
  hash          String   @unique
  templateType  String
  title         String
  prompt        String
  inputData     Json
  generatedData Json
  createdBy     String   @default("admin")
  driveFileId   String?
  driveUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([hash])
  @@index([templateType])
  @@index([createdAt])
  @@map("generated_documents")
}

model Source {
  id        String   @id @default(cuid())
  type      String   // "github" | "mcp" | "drive"
  label     String
  config    Json     // type-specific config (url, token, folderId, etc.)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@map("sources")
}
