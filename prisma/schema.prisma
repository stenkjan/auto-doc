generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
}

model GeneratedDocument {
  id            String   @id @default(cuid())
  hash          String   @unique
  templateType  String
  title         String
  prompt        String
  inputData     Json
  generatedData Json
  createdBy     String   @default("admin")
  driveFileId   String?
  driveUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([hash])
  @@index([templateType])
  @@index([createdAt])
  @@map("generated_documents")
}

model Source {
  id        String   @id @default(cuid())
  type      String   // "github" | "mcp" | "drive"
  label     String
  config    Json     // type-specific config (url, token, folderId, etc.)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@map("sources")
}
