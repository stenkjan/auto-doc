generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model GeneratedDocument {
  id            String   @id @default(cuid())
  hash          String   @unique
  templateType  String
  title         String
  prompt        String
  inputData     String
  generatedData String
  createdBy     String   @default("admin")
  driveFileId   String?
  driveUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([hash])
  @@index([templateType])
  @@index([createdAt])
  @@map("generated_documents")
}

model Source {
  id        String   @id @default(cuid())
  type      String   // "github" | "mcp" | "drive"
  label     String
  config    String   // type-specific config (url, token, folderId, etc.) stored as JSON string
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@map("sources")
}
